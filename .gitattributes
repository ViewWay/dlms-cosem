# Auto detect text files and normalise line endings
* text=auto

# Python source — LF in repo, native checkout (LF on Unix, CRLF on Windows)
*.py text eol=lf
*.pyx text eol=lf
*.pyi text eol=lf

# Config / markup
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.rst text eol=lf
*.txt text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.svg text eol=lf

# Shell scripts — must be LF
*.sh text eol=lf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Windows scripts keep CRLF
*.cmd text eol=crlf

# Binary — leave untouched
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.lock binary
